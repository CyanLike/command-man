      { "command": "grep -v '^#' config.ini | grep -v '^$'", "description": "排除注释行和空行" }
    ]
  },
  {
    "id": "linux-find",
    "name": "find",
    "platform": "Linux",
    "summary": "按名称、类型、大小或时间递归查找文件",
    "aliases": ["查找文件", "搜索目录"],
    "keywords": ["name", "size", "mtime", "exec"],
    "simple": [
      { "command": "find . -name '*.log'", "description": "查找当前目录下的日志文件" },
      { "command": "find . -type d -name node_modules", "description": "查找名为 node_modules 的目录" }
    ],
    "full": [
      { "command": "find /var/log -type f -size +100M -printf '%s %p\\n' | sort -nr", "description": "按大小列出超过 100MB 的日志" },
      { "command": "find . -type f -mtime -7 -not -path './.git/*'", "description": "查找 7 天内修改且不在 .git 中的文件" },
      { "command": "find . -type f -name '*.tmp' -exec rm -i {} +", "description": "逐批确认删除临时文件" }
    ]
  },
  {
