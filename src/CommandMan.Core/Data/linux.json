  {
    "id": "linux-grep",
    "name": "grep",
    "platform": "Linux",
    "summary": "按文本或正则表达式搜索内容",
    "aliases": ["文本搜索", "匹配"],
    "keywords": ["regex", "递归", "行号", "过滤"],
    "simple": [
      { "command": "grep 'error' app.log", "description": "在文件中搜索 error" },
      { "command": "grep -in 'error' app.log", "description": "忽略大小写并显示行号" }
    ],
    "full": [
      { "command": "grep -RIn --exclude-dir=.git -E 'TODO|FIXME' .", "description": "递归搜索多个模式并排除 .git" },
