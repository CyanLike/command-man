  },
  {
    "id": "windows-get-command",
    "name": "Get-Command",
    "platform": "Windows",
    "summary": "查找 PowerShell 命令、别名和可执行程序",
    "aliases": ["gcm", "查命令"],
    "keywords": ["powershell", "module", "alias", "语法"],
    "simple": [
      { "command": "Get-Command *service*", "description": "按名称搜索命令" },
      { "command": "Get-Command git", "description": "查看命令实际解析到的位置" }
    ],
    "full": [
      { "command": "Get-Command -Module Microsoft.PowerShell.Management", "description": "列出指定模块提供的命令" },
      { "command": "Get-Command Get-ChildItem -Syntax", "description": "显示命令的全部语法形式" }
    ]
  },
  {
    "id": "windows-get-nettcpconnection",
    "name": "Get-NetTCPConnection",
    "platform": "Windows",
    "summary": "使用 PowerShell 查询 TCP 连接与监听端口",
    "aliases": ["tcp连接", "端口进程"],
    "keywords": ["powershell", "listen", "pid", "network"],
    "simple": [
      { "command": "Get-NetTCPConnection -State Listen", "description": "查看所有 TCP 监听端口" }
    ],
    "full": [
      { "command": "Get-NetTCPConnection -LocalPort 8080 | Select-Object LocalAddress,LocalPort,State,OwningProcess", "description": "查找占用 8080 端口的进程" },
      { "command": "Get-NetTCPConnection | Group-Object State | Sort-Object Count -Descending", "description": "按状态统计 TCP 连接" }
    ]
  }
]
