    "full": [
      { "command": "Test-NetConnection example.com -Port 443 -InformationLevel Detailed", "description": "输出详细 TCP 诊断信息" },
      { "command": "Test-NetConnection 8.8.8.8 -TraceRoute", "description": "执行路由跟踪" }
