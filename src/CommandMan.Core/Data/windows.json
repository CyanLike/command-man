      { "command": "DISM /Online /Cleanup-Image /CheckHealth", "description": "快速检查映像是否损坏（管理员）" }
    ],
    "full": [
      { "command": "DISM /Online /Cleanup-Image /ScanHealth", "description": "完整扫描映像损坏情况" },
