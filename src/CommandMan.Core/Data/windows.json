[
  {
    "id": "windows-ipconfig",
    "name": "ipconfig",
    "platform": "Windows",
    "summary": "查看和刷新 Windows 网络配置",
    "aliases": ["网络配置", "ip"],
    "keywords": ["dns", "dhcp", "网卡", "地址"],
    "simple": [
      { "command": "ipconfig", "description": "查看基本 IP 配置" },
      { "command": "ipconfig /all", "description": "查看完整网络适配器信息" }
    ],
    "full": [
      { "command": "ipconfig /flushdns", "description": "清空本机 DNS 缓存" },
      { "command": "ipconfig /release && ipconfig /renew", "description": "释放并重新获取 DHCP 地址" }
    ]
  },
  {
    "id": "windows-ping",
    "name": "ping",
    "platform": "Windows",
    "summary": "测试目标主机的网络连通性与延迟",
    "aliases": ["连通性", "延迟"],
    "keywords": ["icmp", "网络", "诊断"],
    "simple": [
      { "command": "ping example.com", "description": "测试域名连通性" },
      { "command": "ping 8.8.8.8", "description": "测试 IP 连通性" }
    ],
    "full": [
      { "command": "ping -n 10 example.com", "description": "发送 10 个请求" },
      { "command": "ping -t example.com", "description": "持续测试直到手动停止" },
      { "command": "ping -4 example.com", "description": "强制使用 IPv4" }
    ]
  },
  {
    "id": "windows-tracert",
    "name": "tracert",
    "platform": "Windows",
    "summary": "跟踪数据包到目标主机所经过的路由",
    "aliases": ["路由跟踪", "traceroute"],
    "keywords": ["网络", "跳数", "诊断"],
    "simple": [
      { "command": "tracert example.com", "description": "跟踪到目标域名的路由" }
    ],
    "full": [
      { "command": "tracert -d example.com", "description": "跳过 DNS 解析以加快跟踪" },
      { "command": "tracert -h 20 -w 1000 example.com", "description": "限制 20 跳且每跳等待 1 秒" }
    ]
  },
  {
    "id": "windows-netstat",
    "name": "netstat",
    "platform": "Windows",
    "summary": "查看网络连接、监听端口和进程",
    "aliases": ["端口", "连接"],
    "keywords": ["tcp", "udp", "pid", "listen"],
    "simple": [
      { "command": "netstat -ano", "description": "列出全部连接、监听端口和 PID" }
    ],
    "full": [
      { "command": "netstat -ano | findstr :8080", "description": "查找占用 8080 端口的连接" },
      { "command": "netstat -abno", "description": "以管理员权限显示关联程序" }
    ]
  },
  {
    "id": "windows-tasklist",
    "name": "tasklist",
    "platform": "Windows",
    "summary": "列出本机正在运行的进程",
    "aliases": ["进程列表", "ps"],
    "keywords": ["process", "pid", "程序"],
    "simple": [
      { "command": "tasklist", "description": "列出全部进程" },
      { "command": "tasklist | findstr chrome", "description": "查找名称包含 chrome 的进程" }
    ],
    "full": [
      { "command": "tasklist /FI \"PID eq 1234\"", "description": "按 PID 筛选进程" },
      { "command": "tasklist /SVC /FO TABLE", "description": "同时显示进程承载的服务" }
    ]
  },
  {
    "id": "windows-taskkill",
    "name": "taskkill",
    "platform": "Windows",
    "summary": "按进程名或 PID 终止进程",
    "aliases": ["结束进程", "kill"],
    "keywords": ["process", "pid", "强制"],
    "simple": [
      { "command": "taskkill /PID 1234", "description": "按 PID 结束进程" },
      { "command": "taskkill /IM notepad.exe", "description": "按程序名结束进程" }
    ],
    "full": [
      { "command": "taskkill /F /T /PID 1234", "description": "强制结束进程及其子进程" },
      { "command": "taskkill /F /FI \"STATUS eq NOT RESPONDING\"", "description": "强制结束所有无响应进程" }
    ]
  },
  {
    "id": "windows-systeminfo",
    "name": "systeminfo",
    "platform": "Windows",
    "summary": "显示操作系统、硬件、补丁和启动信息",
    "aliases": ["系统信息", "版本"],
    "keywords": ["os", "hotfix", "内存", "启动"],
    "simple": [
      { "command": "systeminfo", "description": "查看完整系统信息" }
    ],
    "full": [
      { "command": "systeminfo | findstr /B /C:\"OS Name\" /C:\"OS Version\"", "description": "仅查看系统名称和版本" },
      { "command": "systeminfo /FO CSV > systeminfo.csv", "description": "以 CSV 格式导出系统信息" }
    ]
  },
  {
    "id": "windows-winget",
    "name": "winget",
    "platform": "Windows",
    "summary": "搜索、安装和升级 Windows 软件包",
    "aliases": ["包管理", "软件安装"],
