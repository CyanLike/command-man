  {
    "id": "windows-where",
    "name": "where",
    "platform": "Windows",
    "summary": "在 PATH 或指定目录中查找文件",
    "aliases": ["查找程序", "which"],
    "keywords": ["path", "文件", "可执行"],
    "simple": [
      { "command": "where git", "description": "查找 PATH 中的 git 可执行文件" }
    ],
    "full": [
      { "command": "where /R C:\\Users *.log", "description": "递归查找指定目录中的日志文件" },
      { "command": "where /F /R . *.dll", "description": "递归查找 DLL 并用引号输出路径" }
    ]
  },
  {
    "id": "windows-findstr",
    "name": "findstr",
    "platform": "Windows",
    "summary": "在文本或命令输出中搜索字符串",
    "aliases": ["文本搜索", "grep"],
    "keywords": ["regex", "管道", "匹配"],
    "simple": [
      { "command": "findstr \"error\" app.log", "description": "在文件中搜索 error" },
      { "command": "ipconfig | findstr IPv4", "description": "从命令输出中筛选 IPv4 行" }
    ],
    "full": [
      { "command": "findstr /S /I /N \"TODO FIXME\" *.cs", "description": "递归且忽略大小写搜索并显示行号" },
      { "command": "findstr /R /C:\"^ERROR.*timeout$\" app.log", "description": "使用正则表达式匹配整行" }
    ]
  },
  {
    "id": "windows-robocopy",
    "name": "robocopy",
    "platform": "Windows",
    "summary": "可靠地复制、同步和镜像目录",
    "aliases": ["目录复制", "同步"],
    "keywords": ["backup", "mirror", "备份", "多线程"],
    "simple": [
      { "command": "robocopy C:\\Source D:\\Backup /E", "description": "复制目录及全部子目录" }
    ],
    "full": [
      { "command": "robocopy C:\\Source D:\\Mirror /MIR /COPY:DAT /R:2 /W:2", "description": "镜像目录并限制失败重试" },
      { "command": "robocopy C:\\Source D:\\Backup /E /MT:16 /LOG:backup.log", "description": "使用 16 线程复制并写入日志" }
    ]
  },
  {
    "id": "windows-sfc",
    "name": "sfc",
    "platform": "Windows",
    "summary": "检查并修复受保护的 Windows 系统文件",
    "aliases": ["系统文件检查", "修复"],
    "keywords": ["scan", "verify", "管理员"],
    "simple": [
      { "command": "sfc /scannow", "description": "扫描并自动修复系统文件（管理员）" }
    ],
    "full": [
      { "command": "sfc /verifyonly", "description": "仅扫描，不执行修复" },
      { "command": "sfc /scanfile=C:\\Windows\\System32\\kernel32.dll", "description": "扫描并修复指定系统文件" }
    ]
  },
  {
    "id": "windows-dism",
    "name": "DISM",
    "platform": "Windows",
    "summary": "检查和修复 Windows 映像组件存储",
