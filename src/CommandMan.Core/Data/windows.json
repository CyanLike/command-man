  },
  {
    "id": "windows-get-process",
    "name": "Get-Process",
    "platform": "Windows",
    "summary": "使用 PowerShell 查看和筛选进程",
    "aliases": ["gps", "进程"],
    "keywords": ["powershell", "cpu", "memory", "pid"],
    "simple": [
      { "command": "Get-Process", "description": "列出全部进程" },
      { "command": "Get-Process chrome", "description": "查看 Chrome 进程" }
    ],
    "full": [
      { "command": "Get-Process | Sort-Object CPU -Descending | Select-Object -First 10", "description": "查看累计 CPU 时间最高的 10 个进程" },
      { "command": "Get-Process | Sort-Object WorkingSet64 -Descending | Select-Object -First 10 Name,Id,@{N='MB';E={[math]::Round($_.WorkingSet64/1MB)}}", "description": "查看内存占用最高的 10 个进程" }
    ]
  },
  {
    "id": "windows-get-service",
    "name": "Get-Service",
    "platform": "Windows",
    "summary": "使用 PowerShell 查看 Windows 服务状态",
    "aliases": ["gsv", "服务"],
    "keywords": ["powershell", "running", "stopped"],
    "simple": [
      { "command": "Get-Service", "description": "列出全部 Windows 服务" },
      { "command": "Get-Service -Name wuauserv", "description": "查看 Windows Update 服务" }
    ],
    "full": [
      { "command": "Get-Service | Where-Object Status -eq 'Running'", "description": "仅显示正在运行的服务" },
      { "command": "Get-Service -DisplayName '*update*' | Format-Table Status,Name,DisplayName", "description": "按显示名称筛选并格式化输出" }
    ]
  },
  {
    "id": "windows-get-childitem",
    "name": "Get-ChildItem",
    "platform": "Windows",
    "summary": "使用 PowerShell 列出和递归查找文件",
    "aliases": ["gci", "dir", "ls"],
    "keywords": ["powershell", "文件", "目录", "递归"],
    "simple": [
      { "command": "Get-ChildItem", "description": "列出当前目录内容" },
      { "command": "Get-ChildItem -Force", "description": "包含隐藏项" }
    ],
    "full": [
      { "command": "Get-ChildItem -Recurse -Filter *.log -File", "description": "递归查找所有日志文件" },
      { "command": "Get-ChildItem -Recurse -File | Sort-Object Length -Descending | Select-Object -First 20 FullName,Length", "description": "查找最大的 20 个文件" }
    ]
  },
  {
    "id": "windows-select-string",
    "name": "Select-String",
    "platform": "Windows",
    "summary": "使用 PowerShell 正则搜索文本",
    "aliases": ["sls", "grep", "文本搜索"],
    "keywords": ["powershell", "regex", "匹配", "行号"],
    "simple": [
      { "command": "Select-String -Path app.log -Pattern 'error'", "description": "在日志中搜索 error" }
    ],
    "full": [
      { "command": "Get-ChildItem -Recurse -File | Select-String -Pattern 'TODO|FIXME'", "description": "递归搜索多个正则关键字" },
      { "command": "Select-String -Path *.log -Pattern 'timeout' -Context 2,3", "description": "显示匹配行前 2 行和后 3 行" }
    ]
  },
  {
    "id": "windows-test-netconnection",
    "name": "Test-NetConnection",
    "platform": "Windows",
